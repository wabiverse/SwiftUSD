--- This is what an import might look like.
--- #import $TOOLS/HdSt/shaders/sphereFaceCull.glslfx


--- --------------------------------------------------------------------------
-- glsl SphereFaceCull.Fragment.None

void DiscardBasedOnShading(bool frontFacing)
{
}

--- --------------------------------------------------------------------------
-- glsl SphereFaceCull.Fragment.FrontFacing

void DiscardBasedOnShading(bool frontFacing)
{
    if (frontFacing) {
        discard;
    }
}

--- --------------------------------------------------------------------------
-- glsl SphereFaceCull.Fragment.BackFacing

void DiscardBasedOnShading(bool frontFacing)
{
    if (!frontFacing) {
        discard;
    }
}
