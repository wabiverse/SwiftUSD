--- This is what an import might look like.
--- #import $TOOLS/HdSt/shaders/sphereNormal.glslfx


--- --------------------------------------------------------------------------
-- glsl SphereNormal.Fragment.SingleSided

vec3 GetShadingNormal(vec3 N, bool frontFacing)
{
    return N;
}

--- --------------------------------------------------------------------------
-- glsl SphereNormal.Fragment.DoubleSided

vec3 GetShadingNormal(vec3 N, bool frontFacing)
{
    return frontFacing ? N : -N;
}
